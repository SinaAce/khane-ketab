{
  "name": "ebook-marketplace",
  "version": "0.1.0",
  "description": "خانه کتاب — مارکت‌پلیس فارسی کتاب الکترونیکی و پادکست با Next.js و Prisma",
  "private": true,
  "scripts": {
    "dev": "next dev --webpack",
    "db:dev": "prisma dev -n ebook-marketplace",
    "db:dev:fix": "powershell -ExecutionPolicy Bypass -File scripts/clear-prisma-dev-lock.ps1",
    "db:check": "tsx scripts/db-check.mts",
    "build": "next build --webpack",
    "start": "next start",
    "lint": "eslint",
    "db:generate": "prisma generate",
    "db:migrate": "prisma migrate dev",
    "db:seed": "tsx prisma/seed.ts",
    "db:import": "tsx prisma/import-archive.ts",
    "db:studio": "prisma studio",
    "icons:generate": "node scripts/generate-favicons.mjs",
    "postinstall": "prisma generate"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.1079.0",
    "@aws-sdk/s3-request-presigner": "^3.1079.0",
    "@prisma/adapter-pg": "^7.8.0",
    "@prisma/client": "^7.8.0",
    "bcryptjs": "^3.0.3",
    "clsx": "^2.1.1",
    "dotenv": "^17.4.2",
    "lucide-react": "^1.23.0",
    "next": "16.2.10",
    "next-auth": "^5.0.0-beta.31",
    "next-themes": "^0.4.6",
    "nextjs-toploader": "^3.9.17",
    "pdfjs-dist": "^5.4.296",
    "pg": "^8.22.0",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "react-pdf": "^10.4.1",
    "tailwind-merge": "^3.6.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4",
    "@types/bcryptjs": "^2.4.6",
    "@types/node": "^20",
    "@types/pg": "^8.20.0",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "eslint": "^9",
    "eslint-config-next": "16.2.10",
    "prisma": "^7.8.0",
    "tailwindcss": "^4",
    "tsx": "^4.23.0",
    "typescript": "^5"
  }
}
